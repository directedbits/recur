*.exe

# Plugin binaries built in-place via `go build` (instead of `task build:<name>`
# which puts them under bin/). Matches plugins/<name>/<name>.
/plugins/calendar/calendar
/plugins/devicemonitor/devicemonitor
/plugins/docker/docker
/plugins/fileevents/fileevents
/plugins/mqtt/mqtt
/plugins/timer/timer
/plugins/webhook/webhook

# Generated protobuf (*.pb.go) is committed, not ignored: Go distributes
# modules as source and never runs `buf generate` on the consumer side, so
# `go install`/`go get` needs the generated code present in the tagged tree.
# Regenerate with `buf generate` (see api/buf.gen.yaml); CI checks for drift.

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temp files from plugin install/extract
recur-download-*
recur-extract-*

